rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
//  D&D Nexus — Firestore security rules
//  Deploy with:  firebase deploy --only firestore:rules
//
//  Model
//  ─────
//  • SuperAdmin = the single account with email fonti.alessandro98@gmail.com
//  • Allowed users = SuperAdmin OR an entry in /invites/{lowercased-email}
//  • Per-character documents are owned by the creator (userId field)
//  • Shared catalogs (spells, skills, icons, widgets) are READ by any allowed
//    user and WRITE only by the SuperAdmin.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isSuperAdmin() {
      return isSignedIn() && userEmail() == 'fonti.alessandro98@gmail.com';
    }

    function isInvited() {
      return isSignedIn() && exists(/databases/$(database)/documents/invites/$(userEmail()));
    }

    function isAllowed() {
      return isSuperAdmin() || isInvited();
    }

    // ── Invites: only the SuperAdmin can read/write the allowlist.
    //    Allowed users may read their *own* invite doc to confirm access.
    match /invites/{email} {
      allow read: if isSuperAdmin() || (isSignedIn() && email == userEmail());
      allow write: if isSuperAdmin();
    }

    // ── Characters: owned by their creator, gated by allowlist.
    //    Also readable by the campaign master of a linked character.
    match /characters/{charId} {
      allow read: if isAllowed() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.masterId != null && resource.data.masterId == request.auth.uid)
      );
      allow update, delete: if isAllowed()
        && resource.data.userId == request.auth.uid;
      allow create: if isAllowed()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Per-user settings: owned by uid, gated by allowlist.
    match /userSettings/{uid} {
      allow read, write: if isAllowed() && request.auth.uid == uid;
    }

    // ── Shared catalogs: any allowed user can read; only SuperAdmin writes.
    match /catalog_spells/{id}   { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_skills/{id}   { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_feats/{id}    { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_icons/{id}    { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_widgets/{id}   { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_creatures/{id} { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_races/{id}     { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_classes/{id}   { allow read: if isAllowed(); allow write: if isSuperAdmin(); }
    match /catalog_languages/{id} { allow read: if isAllowed(); allow write: if isSuperAdmin(); }

    // ── Feedback threads: users own their thread; SuperAdmin reads/writes all.
    match /feedback/{userId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isAllowed() && request.auth.uid == userId;
    }

    match /feedback/{userId}/messages/{msgId} {
      allow read, write: if isSuperAdmin();
      allow read: if isAllowed() && request.auth.uid == userId;
      // Users can only create messages from themselves
      allow create: if isAllowed()
        && request.auth.uid == userId
        && request.resource.data.from == 'user';
      // Users can delete only their own messages
      allow delete: if isAllowed()
        && request.auth.uid == userId
        && resource.data.from == 'user';
    }

    // ── Campaigns: created by masters, joined by players.
    match /campaigns/{campaignId} {
      // Master or linked players can read
      allow read: if isAllowed();
      // Only the master creates/deletes
      allow create: if isAllowed()
        && request.resource.data.masterId == request.auth.uid;
      allow delete: if isAllowed()
        && resource.data.masterId == request.auth.uid;
      // Master can update anything; players can update to join/leave their own entry
      allow update: if isAllowed() && (
        resource.data.masterId == request.auth.uid ||
        request.auth.uid in resource.data.playerIds ||
        // Joining: user is not yet a player (adding themselves)
        !(request.auth.uid in resource.data.playerIds)
      );

      // Chat threads per player
      match /chats/{playerId} {
        allow read, write: if isAllowed() && (
          request.auth.uid == playerId ||
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId == request.auth.uid
        );

        match /messages/{msgId} {
          allow read: if isAllowed() && (
            request.auth.uid == playerId ||
            get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId == request.auth.uid
          );
          allow create: if isAllowed() && (
            (request.auth.uid == playerId && request.resource.data.from == 'player') ||
            (get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId == request.auth.uid
              && request.resource.data.from == 'master')
          );
          allow delete: if isAllowed() && (
            request.auth.uid == playerId ||
            get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId == request.auth.uid
          );
        }
      }

      // Glossary entries: master writes, players read their visible entries
      match /glossaryEntries/{entryId} {
        allow read: if isAllowed() && (
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.playerIds
        );
        allow write: if isAllowed() &&
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId == request.auth.uid;
      }
    }
  }
}
