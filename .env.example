VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# === Google Workspace integration (Drive + Picker) ===
# OAuth 2.0 Web client ID (Google Cloud Console → Credentials)
VITE_GOOGLE_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
# Browser API key restricted to Drive API + Picker API
VITE_GOOGLE_API_KEY=your_browser_api_key

# === Gemini AI ===
# Get one at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key
